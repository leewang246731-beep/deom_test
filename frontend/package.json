{
  "name": "saas-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8093",
    "dev:admin": "vite --port 8093",
    "dev:merchant": "vite --config vite.config.merchant.js",
    "dev:service": "vite --config vite.config.service.js",
    "build": "vite build",
    "build:admin": "vite build --outDir dist-admin",
    "build:merchant": "vite build --config vite.config.merchant.js",
    "build:service": "vite build --config vite.config.service.js",
    "preview": "vite preview",
    "generate:api": "openapi-typescript http://localhost:8012/openapi.json -o ./src/api/types/openapi.d.ts",
    "typecheck": "vue-tsc --noEmit",
    "lint": "vue-tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "echarts": "^5.5.0",
    "element-plus": "^2.5.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-echarts": "^6.7.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "openapi-typescript": "^7.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0"
  }
}
